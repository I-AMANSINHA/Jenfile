pipeline {
    agent any

    environment {
        APP_NAME  = 'my-local-app'
        HOST_PORT = '8085'  // The port you will use in your browser to view the app
    }

    stages {
        stage('1. Pull Code from GitHub') {
            steps {
                // Automatically pulls the latest code from your linked GitHub repository
                checkout scm
            }
        }

        stage('2. Build Docker Image') {
            steps {
                script {
                    echo "Building the Docker image from Dockerfile..."
                    sh "docker build -t ${APP_NAME}:latest ."
                }
            }
        }

        stage('3. Deploy Local Container') {
            steps {
                script {
                    echo "Cleaning up any old container running on port ${HOST_PORT}..."
                    sh "docker stop ${APP_NAME} || true"
                    sh "docker rm ${APP_NAME} || true"
                    
                    echo "Starting the new container..."
                    // Maps your host machine's port 8085 to the container's internal port 80
                    sh "docker run -d --name ${APP_NAME} -p ${HOST_PORT}:80 ${APP_NAME}:latest"
                }
            }
        }
    }
}

